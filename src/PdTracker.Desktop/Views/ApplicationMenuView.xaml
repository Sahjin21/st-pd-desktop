<UserControl x:Class="PdTracker.Desktop.Views.ApplicationMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="#2D5A8A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A6EA5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E4070"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A3A5C" Padding="20,16">
            <Grid>
                <TextBlock Text="Application Menu" FontSize="22" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="← Back to Main Menu"
                        HorizontalAlignment="Right"
                        Style="{StaticResource MenuButton}"
                        Background="#3A3A3A"
                        Click="Back_Click"/>
            </Grid>
        </Border>

        <!-- Button Grid: 4 columns -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 1: Edit Application, New Application, No Action, Add Action, Search -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Menu Functions" FontSize="12" FontWeight="SemiBold"
                               Foreground="#888" Margin="8,0,0,8"/>
                    <Button Content="Edit Application" Style="{StaticResource MenuButton}"
                            Tag="EditApplication" Click="Menu_Click"/>
                    <Button Content="New Application" Style="{StaticResource MenuButton}"
                            Tag="NewApplication" Click="Menu_Click"/>
                    <Button Content="No Action" Style="{StaticResource MenuButton}"
                            Tag="NoAction" Click="Menu_Click"/>
                    <Button Content="Add Action" Style="{StaticResource MenuButton}"
                            Tag="AddAction" Click="Menu_Click"/>
                    <Button Content="Search" Style="{StaticResource MenuButton}"
                            Tag="SearchDefendant" Click="Menu_Click"/>
                </StackPanel>

                <!-- Column 2: Edit Action, Appoint Adult, Add/Edit EIA Result, EIA Plea Sheet, Search Paid Voucher -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Menu Functions" FontSize="12" FontWeight="SemiBold"
                               Foreground="#888" Margin="8,0,0,8"/>
                    <Button Content="Edit Action" Style="{StaticResource MenuButton}"
                            Tag="EditAction" Click="Menu_Click"/>
                    <Button Content="Appoint Adult" Style="{StaticResource MenuButton}"
                            Tag="AppointAdult" Click="Menu_Click"/>
                    <Button Content="Add/Edit EIA Result" Style="{StaticResource MenuButton}"
                            Tag="AddEditEIAResult" Click="Menu_Click"/>
                    <Button Content="EIA Plea Sheet" Style="{StaticResource MenuButton}"
                            Tag="EIAPleaSheet" Click="Menu_Click"/>
                    <Button Content="Search Paid Voucher" Style="{StaticResource MenuButton}"
                            Tag="SearchPaidVoucher" Click="Menu_Click"/>
                </StackPanel>

                <!-- Column 3: Edit Attorney, Search AKA, Add Paid Voucher, Add Visitation -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Menu Functions" FontSize="12" FontWeight="SemiBold"
                               Foreground="#888" Margin="8,0,0,8"/>
                    <Button Content="Edit Attorney" Style="{StaticResource MenuButton}"
                            Tag="EditAttorney" Click="Menu_Click"/>
                    <Button Content="Search AKA" Style="{StaticResource MenuButton}"
                            Tag="SearchAKA" Click="Menu_Click"/>
                    <Button Content="Add Paid Voucher" Style="{StaticResource MenuButton}"
                            Tag="AddPaidVoucher" Click="Menu_Click"/>
                    <Button Content="Add Visitation" Style="{StaticResource MenuButton}"
                            Tag="AddVisitation" Click="Menu_Click"/>
                </StackPanel>

                <!-- Column 4: Menu Categories -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Menu Categories" FontSize="12" FontWeight="SemiBold"
                               Foreground="#888" Margin="8,0,0,8"/>
                    <Button Content="Document Menu" Style="{StaticResource MenuButton}"
                            Tag="DocumentMenu" Click="Menu_Click"/>
                    <Button Content="Reports Menu" Style="{StaticResource MenuButton}"
                            Tag="ReportsMenu" Click="Menu_Click"/>
                    <Button Content="Professional" Style="{StaticResource MenuButton}"
                            Tag="Professional" Click="Menu_Click"/>
                    <Button Content="Administrator" Style="{StaticResource MenuButton}"
                            Tag="AdministratorMenu" Click="Menu_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
