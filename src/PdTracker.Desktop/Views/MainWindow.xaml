<Window x:Class="PdTracker.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PdTracker.Desktop.ViewModels"
        Title="PD Tracker - Georgia State Public Defender"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="#2D5A8A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A6EA5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E4070"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="#1A3A5C" Foreground="White" Padding="4,2">
            <MenuItem Header="_File" Foreground="White">
                <MenuItem Header="Change _Database Location..."
                          Command="{Binding ChangeDatabaseCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help" Foreground="White">
                <MenuItem Header="_About PD Tracker" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Layout: Left Nav + Content + Right Nav -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Left Navigation Panel: Common Functions -->
            <Border Grid.Column="0" Background="#1A3A5C">
                <StackPanel Margin="10,20">
                    <TextBlock Text="PD Tracker"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White" Margin="10,0,0,24"/>

                    <Button Content="New Application" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="NewApplication"/>
                    <Button Content="Search Defendant" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="SearchDefendant"/>
                    <Button Content="Edit Application" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="EditApplication"/>
                    <Button Content="Search Voucher" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="SearchVoucher"/>
                    <Button Content="Search by Booking #" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="SearchByBooking"/>
                    <Button Content="Add Attorney List" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="AddAttorney"/>
                    <Button Content="Edit Attorney List" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="EditAttorney"/>
                    <Button Content="Search Child" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="SearchChild"/>

                    <Separator Margin="0,20" Background="#3A5A7A"/>

                    <Button Content="Exit" Style="{StaticResource MenuButton}"
                            Background="#8B2020"
                            Command="{Binding ExitCommand}"/>
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <Border Grid.Column="1" Padding="20">
                <ContentControl x:Name="ContentArea"/>
            </Border>

            <!-- Right Navigation Panel: Menu Categories -->
            <Border Grid.Column="2" Background="#1A3A5C">
                <StackPanel Margin="10,20">
                    <TextBlock Text="Menu"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White" Margin="10,0,0,24"/>

                    <Button Content="Application Menu" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="ApplicationMenu"/>
                    <Button Content="Document Menu" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="DocumentMenu"/>
                    <Button Content="Professional" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Professional"/>
                    <Button Content="Reports Menu" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="ReportsMenu"/>
                    <Button Content="Administrator Menu" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="AdministratorMenu"/>
                    <Button Content="CD Number Reverse Order" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="CDNumberReverse"/>
                    <Button Content="Defendant A-Z" Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="DefendantAZ"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
