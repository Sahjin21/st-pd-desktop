<UserControl x:Class="PdTracker.Desktop.Views.DefendantSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PdTracker.Desktop.ViewModels"
             xmlns:conv="clr-namespace:PdTracker.Desktop.Converters">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Border Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <!-- SOID field — shown for Search by Booking # and Search Child modes -->
                <Grid Margin="0,0,0,8" Visibility="{Binding ShowSoidField, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Booking / SOID" FontSize="11" Foreground="Gray" Margin="4,0,0,2"/>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SoIdSearch, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="10,8"
                                 VerticalContentAlignment="Center"
                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding SoidSuggestions}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <Button Grid.Column="2" Content="Search" Command="{Binding SearchCommand}"
                            Padding="28,8" FontSize="14" Cursor="Hand" VerticalAlignment="Bottom"/>
                </Grid>

                <!-- First + Last Name row — hidden in SOID-only modes -->
                <Grid Margin="0,0,0,8" Visibility="{Binding ShowSoidField, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Last Name" FontSize="11" Foreground="Gray" Margin="4,0,0,2"/>
                        <TextBox Grid.Column="0"
                                 Text="{Binding LastNameSearch, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="10,8"
                                 VerticalContentAlignment="Center"
                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding LastNameSuggestions}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="First Name" FontSize="11" Foreground="Gray" Margin="4,0,0,2"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding FirstNameSearch, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="10,8"
                                 VerticalContentAlignment="Center"
                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding FirstNameSuggestions}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <Button Grid.Column="4" Content="Search" Command="{Binding SearchCommand}"
                            Padding="28,8" FontSize="14" Cursor="Hand" VerticalAlignment="Bottom" Margin="0,0,0,0"/>
                </Grid>

                <!-- Hint -->
                <TextBlock FontSize="11" Foreground="Gray" Margin="4,0,0,0"
                           Text="Enter a SOID to search by booking number."
                           Visibility="{Binding ShowSoidField, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock FontSize="11" Foreground="Gray" Margin="4,0,0,0"
                           Text="Enter a last name, first name, or both to search. Press Enter or click Search."
                           Visibility="{Binding ShowSoidField, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Results + Tabs -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <!-- Search Results Tab -->
            <TabItem Header="Search Results">
                <DataGrid ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedDefendant}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="App #" Binding="{Binding ApplicationNumber}" Width="70"/>
                        <DataGridTextColumn Header="Defendant ID" Binding="{Binding DefendantId}" Width="100"/>
                        <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="120"/>
                        <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="100"/>
                        <DataGridTextColumn Header="DOB" Binding="{Binding DOB, StringFormat={}{0:MM/dd/yyyy}}" Width="90"/>
                        <DataGridTextColumn Header="SOID" Binding="{Binding SOID}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Appointment Info Tab -->
            <TabItem Header="Appoint Info">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <!-- Shows when NO defendant is selected -->
                        <TextBlock Text="Select a defendant to view appointments"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="Gray" FontStyle="Italic"
                                   Visibility="{Binding AppointInfoVm.CurrentAppointment, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>

                        <!-- Shows when defendant IS selected -->
                        <StackPanel Visibility="{Binding AppointInfoVm.CurrentAppointment, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Appointment History" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <DataGrid ItemsSource="{Binding AppointInfoVm.Appointments}"
                                      SelectedItem="{Binding AppointInfoVm.CurrentAppointment}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:MM/dd/yyyy}}" Width="90"/>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="60"/>
                                    <DataGridTextColumn Header="Attorney" Binding="{Binding Attorney.DisplayName}" Width="150"/>
                                    <DataGridTextColumn Header="Date Signed" Binding="{Binding DateSigned, StringFormat={}{0:MM/dd/yyyy}}" Width="90"/>
                                    <DataGridTextColumn Header="Voucher #" Binding="{Binding VoucherNumber}" Width="100"/>
                                    <DataGridCheckBoxColumn Header="GAL" Binding="{Binding GAL}" Width="40"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Court Information Tab -->
            <TabItem Header="Court Information">
                <ScrollViewer Margin="10">
                    <StackPanel>
                        <TextBlock Text="Qualification Info" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Date:" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CourtInfoVm.Qualify.Date, StringFormat={}{0:MM/dd/yyyy}}" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="No Action:" Margin="0,4"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CourtInfoVm.Qualify.NoAction}" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Court Info:" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CourtInfoVm.Qualify.CourtInformation}" TextWrapping="Wrap" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Military:" Margin="0,4"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding CourtInfoVm.Qualify.Military}" Margin="0,4"/>
                        </Grid>

                        <TextBlock Text="Charges" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,10"/>
                        <DataGrid ItemsSource="{Binding CourtInfoVm.Charges}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Case #" Binding="{Binding CaseNumber}" Width="120"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding ChargeType}" Width="80"/>
                                <DataGridTextColumn Header="Charge" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding ChargeDate, StringFormat={}{0:MM/dd/yyyy}}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Warrants" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,10"/>
                        <DataGrid ItemsSource="{Binding CourtInfoVm.Warrants}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Warrant #" Binding="{Binding WarrantNumber}" Width="120"/>
                                <DataGridTextColumn Header="Case #" Binding="{Binding CaseNumber}" Width="120"/>
                                <DataGridTextColumn Header="Jurisdiction" Binding="{Binding JurisdictionCode}" Width="80"/>
                                <DataGridTextColumn Header="Bond" Binding="{Binding BondAmt, StringFormat={}{0:C}}" Width="80"/>
                                <DataGridCheckBoxColumn Header="Jail" Binding="{Binding Jail}" Width="40"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Comments / Bluesheet Tab -->
            <TabItem Header="Comments">
                <StackPanel Margin="10">
                    <TextBlock Text="Comments" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding CommentVm.Comments}" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Height="150" Margin="0,0,0,20"/>

                    <TextBlock Text="Court Information" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding CommentVm.CourtInfo}" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Height="100" Margin="0,0,0,20"/>

                    <CheckBox Content="Military" IsChecked="{Binding CommentVm.Military}" FontSize="14"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
