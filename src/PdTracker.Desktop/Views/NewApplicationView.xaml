<UserControl x:Class="PdTracker.Desktop.Views.NewApplicationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PdTracker.Desktop.Converters">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Header -->
        <Border Grid.Row="0" Background="#2D5A8A" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding CurrentStep, Converter={StaticResource StepNumberToTitleConverter}}"
                           FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Foreground="#A0C0E0" FontSize="14" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Run Text="Step "/><Run Text="{Binding CurrentStep, Mode=OneWay}"/><Run Text=" of 7"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Step 0: Personal -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=0}">
                    <TextBlock Text="Personal Information" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Defendant ID / SOID:*" Margin="0,6"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Defendant.DefendantId}" Margin="0,4"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Application #" Margin="0,6"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Defendant.ApplicationNumber}" IsReadOnly="True" Background="#EEE" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="First Name:*" Margin="0,6"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Defendant.FirstName}" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Middle Name" Margin="0,6"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Defendant.MiddleName}" Margin="0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Name:*" Margin="0,6"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Defendant.LastName}" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Date of Birth" Margin="0,6"/>
                        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding Defendant.DOB}" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Education" Margin="0,6"/>
                        <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding Defendant.Education}" Margin="0,4"
                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding EducationSuggestions}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Race" Margin="0,6"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Defendant.Race}" Margin="0,4"
                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding RaceSuggestions}"/>

                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Sex" Margin="0,6"/>
                        <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding Defendant.Sex}" Margin="0,4"
                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding SexSuggestions}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="SOID" Margin="0,6"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Defendant.SOID}" Margin="0,4"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Reference 1" Margin="0,6"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Defendant.Reference1}" Margin="0,4"/>

                        <TextBlock Grid.Row="6" Grid.Column="2" Text="Reference 2" Margin="0,6"/>
                        <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding Defendant.Reference2}" Margin="0,4"/>
                    </Grid>
                </StackPanel>

                <!-- Step 1: Address / Phone -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=1}">
                    <TextBlock Text="Address / Phone" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Button Content="+ Add Address" Command="{Binding AddAddressCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Addresses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Street" Margin="0,4"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Street}" Margin="0,2"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="City" Margin="0,4"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding City}" Margin="0,2"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="State" Margin="0,4"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding State}" Width="60" HorizontalAlignment="Left" Margin="0,2"
                                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding StateSuggestions}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Zip" Margin="0,4"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ZipCode}" Width="120" HorizontalAlignment="Left" Margin="0,2"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Phone Numbers" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,16"/>
                    <Button Content="+ Add Phone" Command="{Binding AddPhoneCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Phones}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBox Text="{Binding PhoneNumber}" Width="150" Margin="0,0,8,0"/>
                                    <ComboBox Width="120" SelectedValue="{Binding PhoneType}" Margin="0,0,8,0">
                                        <ComboBoxItem Content="Home"/>
                                        <ComboBoxItem Content="Mobile"/>
                                        <ComboBoxItem Content="Work"/>
                                        <ComboBoxItem Content="Other"/>
                                    </ComboBox>
                                    <Button Content="✕" Command="{Binding DataContext.RemovePhoneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Width="30"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Step 2: Charges (simplified) -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=2}">
                    <TextBlock Text="Charges" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Button Content="+ Add Charge" Command="{Binding AddChargeCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Charges}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Case #" Margin="0,4"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CaseNumber}" Margin="0,2"/>

                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Charge Type" Margin="0,4"/>
                                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding ChargeType}" Margin="0,2"
                                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding ChargeTypeSuggestions}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Charge Date" Margin="0,4"/>
                                        <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding ChargeDate}" Margin="0,2"/>

                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Warrant #" Margin="0,4"/>
                                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding WarrantNumber}" Margin="0,2"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Description" Margin="0,4"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Description}" Margin="0,2"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Step 3: Financial (simplified) -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=3}">
                    <TextBlock Text="Employment" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Button Content="+ Add Employer" Command="{Binding AddEmployerCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Employers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Employer" Margin="0,4"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EmployerName}" Margin="0,2"/>

                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="City" Margin="0,4"/>
                                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding City}" Margin="0,2"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Pay Amount" Margin="0,4"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PayAmt}" Margin="0,2"/>

                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Pay Period" Margin="0,4"/>
                                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding PayPeriod}" Margin="0,2"
                                                 conv:AutoCompleteBehavior.SuggestionSource="{Binding PayPeriodSuggestions}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Time Employed" Margin="0,4"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TimeEmployed}" Margin="0,2"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Step 4: Spouse -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=4}">
                    <TextBlock Text="Spouse Information" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="First Name" Margin="0,6"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Spouse.FirstName}" Margin="0,4"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Middle Name" Margin="0,6"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Spouse.MiddleName}" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Name" Margin="0,6"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Spouse.LastName}" Margin="0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Employed" Margin="0,6"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding Spouse.Employed}" Margin="0,6"/>
                    </Grid>
                </StackPanel>

                <!-- Step 5: Other Financial -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=5}">
                    <TextBlock Text="Other Income Sources" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="(Unemployment, spouse income, etc.)" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,16"/>
                    <!-- Repeatable: hook up similarly to Charges -->
                </StackPanel>

                <!-- Step 6: Comments / Court -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=6}">
                    <TextBlock Text="Comments" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Comments}" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" Height="120" Margin="0,0,0,20"/>

                    <TextBlock Text="Court Comments" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding CourtComments}" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" Height="120" Margin="0,0,0,20"/>

                    <CheckBox Content="Military" IsChecked="{Binding Military}" FontSize="14"/>
                </StackPanel>

                <!-- Step 7: Juvenile -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepVisibilityConverter}, ConverterParameter=7}">
                    <TextBlock Text="Juvenile Dependents" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <Button Content="+ Add Juvenile" Command="{Binding AddJuvenileCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding JuvenileInfo}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Text="{Binding FirstName}" Width="120" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding LastName}" Width="120" Margin="0,0,8,0"/>
                                        <Button Content="✕" Command="{Binding DataContext.RemoveJuvenileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Width="30"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Navigation Footer -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Back" Command="{Binding BackCommand}"
                        IsEnabled="{Binding CanGoBack}" Padding="20,8"/>
                <Button Grid.Column="2" Content="{Binding NextLabel}" Command="{Binding NextCommand}"
                        Padding="24,8" Background="#2D5A8A" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
