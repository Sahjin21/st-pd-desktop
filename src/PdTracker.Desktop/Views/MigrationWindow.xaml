<Window x:Class="PdTracker.Desktop.Views.MigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PD Tracker - Importing Data"
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Importing your data from Access..."
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="0"
                   Text="This may take a few minutes depending on how much data you have."
                   Foreground="#666" Margin="0,28,0,16" FontSize="13"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      BorderBrush="#CCC" BorderThickness="1" Padding="8">
            <TextBlock x:Name="LogText"
                       FontFamily="Consolas" FontSize="12"
                       TextWrapping="Wrap"/>
        </ScrollViewer>

        <Button x:Name="CloseButton" Grid.Row="2"
                Content="Close" IsEnabled="False"
                HorizontalAlignment="Right" Margin="0,12,0,0"
                Padding="24,8" Click="CloseButton_Click"/>
    </Grid>
</Window>
