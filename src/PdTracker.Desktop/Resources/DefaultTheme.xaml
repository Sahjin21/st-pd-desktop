<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:PdTracker.Desktop.Converters">

    <!-- Converters -->
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    <conv:StepVisibilityConverter x:Key="StepVisibilityConverter"/>
    <conv:StepNumberToTitleConverter x:Key="StepNumberToTitleConverter"/>
    <conv:NullToEnabledConverter x:Key="NullToEnabledConverter"/>

    <!-- Base Colors -->
    <SolidColorBrush x:Key="PrimaryBlue" Color="#2D5A8A"/>
    <SolidColorBrush x:Key="PrimaryBlueHover" Color="#3A6EA5"/>
    <SolidColorBrush x:Key="DarkNavy" Color="#1A3A5C"/>
    <SolidColorBrush x:Key="LightGray" Color="#F0F4F8"/>
    <SolidColorBrush x:Key="BorderGray" Color="#CCCCCC"/>

    <!-- Global Styles -->
    <Style TargetType="Button">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="CaretBrush" Value="Black"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="White"/>
        <Setter Property="AlternatingRowBackground" Value="#F5F7FA"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#E0E4EA"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
    </Style>

</ResourceDictionary>
